<resources>
    <!-- Display -->
    <!-- The default peak refresh rate for a given device. -->
    <integer name="config_defaultPeakRefreshRate">90</integer>
    <!-- The default refresh rate for a given device. -->
    <integer name="config_defaultRefreshRate">60</integer>

    <!-- Screen brightness -->
    <integer name="config_screenBrightnessDim">10</integer>
    <integer name="config_screenBrightnessSettingDefault">128</integer>
    <integer name="config_screenBrightnessSettingMaximum">255</integer>
    <integer name="config_screenBrightnessSettingMinimum">2</integer>

    <!-- Whether the display cutout region of the main built-in display should be forced to
         black in software. -->
    <bool name="config_fillMainBuiltInDisplayCutout">true</bool>

    <!-- Display cutout (waterdrop notch) -->
    <string translatable="false" name="config_mainBuiltInDisplayCutout">
        M 502,0
        L 502,0
        A 38,38 0 0,1 578,0
        L 578,0
        Z
        @dp
    </string>

    <!-- The bounding path of the cutout region of the main built-in display.
         Must map to the same region as config_mainBuiltInDisplayCutout. -->
    <string translatable="false" name="config_mainBuiltInDisplayCutoutRectApproximation">
        M 472,0
        h 136
        v 80
        h -136
        Z
        @dp
    </string>

    <!-- Whether WiFi display is supported by this device.
         There are many prerequisites for this feature to work correctly.
         Here are a few of them:
         * The WiFi radio must support WiFi P2P.
         * The WiFi radio must support concurrent connections to the WiFi display and
           to an access point.
         * The Audio Flinger audio_policy.conf file must specify a remote submix module
           that is loaded on demand. -->
    <bool name="config_enableWifiDisplay">true</bool>

    <!-- Flag indicating whether the surface flinger is responsible
         for the creation of the display's protected contents layer-->
    <bool name="config_enableSurfaceFlingerForProtectedContent">true</bool>

    <!-- Whether the device supports Smart Pixels -->
    <bool name="config_enableSmartPixels">true</bool>

    <!-- Telephony -->
    <!-- Indicates whether the device supports single channel (No DSDS) -->
    <bool name="config_voice_capable">true</bool>
    <bool name="config_sms_capable">true</bool>

    <!-- WiFi -->
    <!-- Wifi driver supports IEEE80211AX for softap -->
    <bool name="config_wifiSoftapIeee80211axSupported">false</bool>
    <!-- Indicates that connected MAC randomization is supported on this device -->
    <bool name="config_wifi_connected_mac_randomization_supported">true</bool>
    <!-- Indicates that p2p MAC randomization is supported on this device -->
    <bool name="config_wifi_p2p_mac_randomization_supported">true</bool>
    <!-- Wifi driver supports WPA3-SAE for softap -->
    <bool name="config_wifi_softap_sae_supported">false</bool>

    <!-- Whether device supports double tap to wake -->
    <bool name="config_supportDoubleTapWake">true</bool>

    <!-- Whether the device allows finger print enrollment with screen off -->
    <bool name="config_fingerprintWakeAndUnlock">true</bool>

    <!-- Device supports LED flashlight -->
    <bool name="config_hasFlashlight">true</bool>

    <!-- If true, the screen can be rotated via the accelerometer in all 4
         rotations as the default behavior. -->
    <bool name="config_allowAllRotations">true</bool>

    <!-- Battery -->
    <!-- Shutdown if the battery temperature exceeds (this value * 0.1) Celsius. -->
    <integer name="config_shutdownBatteryTemperature">600</integer>
</resources>
